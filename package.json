{
  "name": "hono-prisma-sample",
  "version": "0.1.0",
  "bin": {
    "hono-prisma-sample": "bin/hono-prisma-sample.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "migrate:dev": "cd lambda/src && bunx dotenv -e .env.local bunx prisma migrate dev",
    "dev": "bunx dotenv -e ./lambda/src/.env.local bun run lambda/src/app.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "aws-cdk": "2.1019.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@hono/zod-validator": "0.2.2",
    "@prisma/client": "6.3.0",
    "@types/aws-lambda": "8.10.147",
    "@types/uuid": "10.0.0",
    "aws-cdk-lib": "2.201.0",
    "constructs": "^10.0.0",
    "dotenv-cli": "8.0.0",
    "hono": "4.6.2",
    "prisma": "6.3.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  }
}
